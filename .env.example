# Runtime settings
VNC_PASSWORD=ubuntu
VNC_GEOMETRY=1920x1080
ROS_DOMAIN_ID=30
PORT=6080

# Build settings (require rebuild to take effect)
ADDITIONAL_PACKAGES=ros-jazzy-turtlebot3 ros-jazzy-turtlebot3-simulations
WORKSPACE_REPOS=https://github.com/ROBOTIS-GIT/turtlebot3_simulations.git#jazzy

# Multiple repos (space-separated):
# WORKSPACE_REPOS=https://github.com/org/repo1.git#main https://github.com/org/repo2.git#jazzy
# Omit #branch to default to the ROS_DISTRO value (jazzy).
