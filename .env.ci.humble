# Build configuration for the pre-built CI image (Humble / Ubuntu 22.04).
# Note: TurtleBot3 simulations on Humble depend on classic Gazebo (gazebo_ros_pkgs)
# which is not available as a deb package. The humble image ships as a clean
# ROS 2 + Ignition Gazebo setup. Users can add their own packages via .env.

ADDITIONAL_PACKAGES=
WORKSPACE_REPOS=
