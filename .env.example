# Runtime settings
VNC_PASSWORD=ubuntu
VNC_GEOMETRY=1920x1080
ROS_DOMAIN_ID=30
PORT=6080

# Build settings (require rebuild to take effect)
# --- Jazzy (Ubuntu 24.04, recommended) ---
ADDITIONAL_PACKAGES=ros-jazzy-turtlebot3 ros-jazzy-turtlebot3-simulations
WORKSPACE_REPOS=https://github.com/ROBOTIS-GIT/turtlebot3_simulations.git#jazzy

# --- Humble (Ubuntu 22.04, alternative) ---
# TurtleBot3 on Humble uses classic Gazebo 11. The gazebo_ros_pkgs package
# is built from source during image creation, so the build takes longer.
# ADDITIONAL_PACKAGES_HUMBLE=ros-humble-turtlebot3 ros-humble-gazebo-dev
# WORKSPACE_REPOS_HUMBLE=https://github.com/ros-simulation/gazebo_ros_pkgs.git#humble https://github.com/ROBOTIS-GIT/turtlebot3_simulations.git#humble
# PORT_HUMBLE=6081

# Multiple repos (space-separated):
# WORKSPACE_REPOS=https://github.com/org/repo1.git#main https://github.com/org/repo2.git#jazzy
# Omit #branch to default to the ROS_DISTRO value.
