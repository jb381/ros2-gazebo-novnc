# Runtime settings
VNC_PASSWORD=ubuntu
VNC_GEOMETRY=1920x1080
ROS_DOMAIN_ID=30
PORT=6080

# Build settings (require rebuild to take effect)
# --- Jazzy (Ubuntu 24.04, default) ---
ADDITIONAL_PACKAGES=ros-jazzy-turtlebot3 ros-jazzy-turtlebot3-simulations
WORKSPACE_REPOS=https://github.com/ROBOTIS-GIT/turtlebot3_simulations.git#jazzy

# --- Humble (Ubuntu 22.04, use --profile humble) ---
# Note: TurtleBot3 simulations on Humble depend on classic Gazebo (gazebo_ros_pkgs)
# which is not available as a deb. The humble variant ships as a clean ROS 2 + Ignition setup.
# ADDITIONAL_PACKAGES=ros-humble-<your-packages>
# WORKSPACE_REPOS=https://github.com/your-org/your_repo.git#humble
# PORT_HUMBLE=6081

# Multiple repos (space-separated):
# WORKSPACE_REPOS=https://github.com/org/repo1.git#main https://github.com/org/repo2.git#jazzy
# Omit #branch to default to the ROS_DISTRO value.
