# Build configuration for the pre-built CI image.
# This file is the single source of truth for what goes into the published image.
# Users can copy .env.example to .env for the same defaults, or customize it.

ADDITIONAL_PACKAGES=ros-jazzy-turtlebot3 ros-jazzy-turtlebot3-simulations
WORKSPACE_REPOS=https://github.com/ROBOTIS-GIT/turtlebot3_simulations.git#jazzy
