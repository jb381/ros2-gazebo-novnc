# Build configuration for the pre-built CI image (Humble / Ubuntu 22.04).
# Uses classic Gazebo 11 (apt) + gazebo_ros_pkgs + turtlebot3_simulations (source).

ADDITIONAL_PACKAGES=ros-humble-turtlebot3 ros-humble-gazebo-dev
WORKSPACE_REPOS=https://github.com/ros-simulation/gazebo_ros_pkgs.git#humble https://github.com/ROBOTIS-GIT/turtlebot3_simulations.git#humble
